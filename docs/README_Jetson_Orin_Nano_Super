# I could only get the above LLM to run by adding the argument "-c 2048" this limits the amount of
# tokens the LLM can use to 2048. It turns out that Release 36.4.2 has got some kind of memory problem
# such that the LLM will only work if it's loaded into contigious memory. So to correct this we need to
# follow the steps to upgrade to Release 36.5 

###################################
###STEP: Upgrade to 36.5 to fix memory problems that llama-server is having
###################################

# Open the NVIDIA L4T APT source file to point to the new 36.5 repository
# Change all instances of r36.4 (or earlier) to r36.5 
 sudo vi /etc/apt/sources.list.d/nvidia-l4t-apt-source.list

# Update Package Lists
 sudo apt update

# Run a full distribution upgrade to update JetPack/L4T packages:
 sudo apt dist-upgrade

# Fix Broken Dependencies and 
# ensure all packages are properly configured:
 sudo apt install --fix-broken -o Dpkg::Options::="--force-overwrite"

# Reboot the Device
 sudo reboot

# Verification After the reboot, verify that the upgrade was successful by 
# checking the new Jetson Linux version:
 cat /etc/nv_tegra_release
# and
 jtop

